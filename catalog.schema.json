{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Video Generation Skills Catalog",
  "type": "object",
  "required": ["name", "version", "skills"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "priority": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "install": { "type": "object" }
  }
}
